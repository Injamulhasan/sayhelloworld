---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { ThemeProvider } from '@/components/ui/theme-toggle';
import { getCollection } from 'astro:content';
import type { MarkdownHeading } from 'astro';

interface Props {
  title?: string;
  currentSlug?: string;
  headings?: MarkdownHeading[];
}

const { title = 'Docs', currentSlug, headings = [] } = Astro.props;

const allDocs = await getCollection('docs');
const sorted = allDocs.sort((a, b) => a.data.order - b.data.order);

const grouped = sorted.reduce<Record<string, typeof sorted>>((acc, doc) => {
  const section = doc.data.section;
  if (!acc[section]) acc[section] = [];
  acc[section].push(doc);
  return acc;
}, {});

// Filter headings to show only h2 and h3 in the Table of Contents
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Docs</title>
    <ThemeProvider />
  </head>
  <body class="min-h-screen flex flex-col bg-background text-foreground font-sans antialiased">
    <Nav />
    
    <div class="flex flex-1 max-w-6xl mx-auto w-full px-6 py-12 gap-10">
      <!-- Left Sidebar (Navigation) -->
      <aside class="hidden md:block w-60 shrink-0">
        <nav class="sticky top-24 space-y-8 pr-4 border-r border-border/40 min-h-[calc(100vh-10rem)]">
          {Object.entries(grouped).map(([section, docs]) => (
            <div>
              <p class="text-xs font-mono font-bold uppercase tracking-widest text-muted-foreground/60 px-3 mb-4">
                {section}
              </p>
              <ul class="space-y-1">
                {docs.map(doc => (
                  <li class="relative">
                    {currentSlug === doc.slug && (
                      <span class="absolute left-0 top-1.5 bottom-1.5 w-[2px] bg-primary rounded-full"></span>
                    )}
                    <a
                      href={`/docs/${doc.slug}`}
                      class={`block text-sm py-1.5 px-3 rounded-md transition-all duration-200 ${
                        currentSlug === doc.slug
                          ? 'text-primary font-semibold bg-primary/5 pl-4'
                          : 'text-muted-foreground hover:text-foreground hover:bg-muted/50 pl-3'
                      }`}
                    >
                      {doc.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </aside>

      <!-- Main Doc Content -->
      <main class="flex-1 min-w-0">
        <article class="prose prose-neutral dark:prose-invert max-w-none 
          prose-headings:font-bold prose-headings:tracking-tight
          prose-h1:text-3xl prose-h1:mb-6 prose-h1:pb-4 prose-h1:border-b prose-h1:border-border/40
          prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4
          prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-sm prose-p:leading-relaxed prose-p:text-muted-foreground dark:prose-p:text-muted-foreground/90
          prose-li:text-sm prose-li:text-muted-foreground dark:prose-li:text-muted-foreground/90
          prose-code:text-xs prose-code:font-mono prose-code:bg-muted/70 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:border prose-code:border-border/30
          prose-pre:rounded-xl prose-pre:border prose-pre:border-border/50 prose-pre:bg-muted/50
          prose-table:text-sm
          prose-th:font-semibold prose-th:text-foreground prose-th:border-b prose-th:border-border/40
          prose-td:text-muted-foreground prose-td:border-b prose-td:border-border/20
        ">
          <slot />
        </article>
      </main>

      <!-- Right Sidebar (Table of Contents) -->
      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block w-52 shrink-0">
          <nav class="sticky top-24 space-y-4 pl-4 border-l border-border/40 min-h-[calc(100vh-10rem)]">
            <p class="text-xs font-mono font-bold uppercase tracking-widest text-muted-foreground/60">
              On This Page
            </p>
            <ul class="space-y-2 text-xs">
              {tocHeadings.map(h => (
                <li class={h.depth === 3 ? "pl-3 border-l border-border/20" : ""}>
                  <a
                    href={`#${h.slug}`}
                    class="text-muted-foreground hover:text-primary transition-colors block py-0.5 leading-relaxed truncate max-w-full"
                    title={h.text}
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>
      )}
    </div>
  </body>
</html>
