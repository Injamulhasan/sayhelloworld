---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Badge } from '@/components/ui/badge';
import { Card, CardHeader, CardTitle, CardDescription, CardContent, CardFooter } from '@/components/ui/card';

const allProjects = await getCollection('projects');
const projects = allProjects.sort((a, b) => parseInt(b.data.year) - parseInt(a.data.year));
---

<Layout title="Projects — Injamul Hasan">
  <div class="max-w-[1100px] mx-auto px-6 py-16">

    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-2xl font-semibold tracking-tight text-foreground mb-3">Projects</h1>
      <p class="text-sm text-muted-foreground leading-relaxed max-w-2xl">
        A curated collection of things I have built — research experiments, production systems,
        developer tooling, and open-source contributions. Each project reflects a specific
        problem I found worth solving.
      </p>
    </div>

    <!-- Filter pills -->
    <div class="flex gap-2 mb-10 flex-wrap" id="filters">
      {['All', 'WEB', 'ML', 'API'].map(cat => (
        <button
          data-filter={cat}
          class={`px-4 py-1.5 rounded-full text-sm font-medium border transition-colors cursor-pointer
            ${cat === 'All' ? 'bg-primary text-primary-foreground border-primary' : 'border-border text-muted-foreground hover:text-foreground hover:border-foreground/30 bg-background'}
          `}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="projects-grid">
      {projects.map(project => (
        <Card
          data-category={project.data.category}
          class="flex flex-col transition-all hover:shadow-md hover:-translate-y-0.5 group/card"
        >
          <CardHeader>
            <div class="flex items-center justify-between gap-3 mb-1">
              <span class="font-mono text-xs text-muted-foreground">{project.data.year}</span>
              <Badge variant="outline" class="text-xs font-mono">{project.data.category}</Badge>
            </div>
            <CardTitle class="text-base leading-snug">{project.data.title}</CardTitle>
            {project.body && (
              <CardDescription class="text-sm leading-relaxed">
                {project.body.split('\n').filter(Boolean)[0]}
              </CardDescription>
            )}
          </CardHeader>

          <CardContent class="flex-1 space-y-3">
            {project.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map(tag => (
                  <Badge variant="secondary" class="text-xs font-mono">{tag}</Badge>
                ))}
              </div>
            )}
            {project.data.features.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {project.data.features.map(f => (
                  <span class="inline-flex items-center px-2 py-0.5 rounded-md border border-border text-xs text-muted-foreground bg-muted/50">{f}</span>
                ))}
              </div>
            )}
          </CardContent>

          <CardFooter class="border-t border-border gap-3 pt-4">
            {project.data.codeUrl && (
              <a href={project.data.codeUrl} target="_blank" rel="noopener noreferrer"
                 class="text-xs text-muted-foreground hover:text-foreground transition-colors font-medium">
                Code
              </a>
            )}
            {project.data.liveUrl && (
              <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer"
                 class="text-xs text-muted-foreground hover:text-foreground transition-colors font-medium">
                Live
              </a>
            )}
            {project.data.demoUrl && (
              <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer"
                 class="text-xs text-muted-foreground hover:text-foreground transition-colors font-medium">
                Demo
              </a>
            )}
          </CardFooter>
        </Card>
      ))}
    </div>
  </div>
</Layout>

<script>
const filters = document.getElementById('filters');
const grid = document.getElementById('projects-grid');

filters?.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('button[data-filter]') as HTMLButtonElement;
  if (!btn) return;

  const filter = btn.dataset.filter!;

  // Update active pill
  filters.querySelectorAll('button').forEach(b => {
    b.classList.remove('bg-primary', 'text-primary-foreground', 'border-primary');
    b.classList.add('border-border', 'text-muted-foreground', 'bg-background');
  });
  btn.classList.add('bg-primary', 'text-primary-foreground', 'border-primary');
  btn.classList.remove('border-border', 'text-muted-foreground', 'bg-background');

  // Show/hide cards
  grid?.querySelectorAll('[data-category]').forEach(card => {
    const el = card as HTMLElement;
    if (filter === 'All' || el.dataset.category === filter) {
      el.style.display = '';
    } else {
      el.style.display = 'none';
    }
  });
});
</script>
