---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Badge } from '@/components/ui/badge';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<Layout title="Blog — Your Name">
  <div class="max-w-4xl mx-auto px-6 py-16">
    <div class="mb-12">
      <h1 class="text-2xl font-semibold tracking-tight text-foreground mb-3">Writing</h1>
      <p class="text-sm text-muted-foreground max-w-xl">
        Thoughts on AI systems, engineering trade-offs, research notes, and the occasional essay.
      </p>
    </div>

    <div class="space-y-px border border-border rounded-xl overflow-hidden">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.slug}`}
          class={`flex flex-col sm:flex-row sm:items-start gap-4 px-5 py-5 bg-card hover:bg-muted/50 transition-colors group ${i > 0 ? 'border-t border-border' : ''}`}
        >
          <div class="flex flex-col gap-1 flex-1 min-w-0">
            <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{post.data.title}</span>
            <span class="text-xs text-muted-foreground leading-relaxed">{post.data.description}</span>
            <div class="flex items-center gap-2 mt-1.5 flex-wrap">
              {post.data.tags.map(tag => (
                <Badge variant="outline" class="text-xs">{tag}</Badge>
              ))}
            </div>
          </div>
          <div class="flex flex-col items-end gap-1 shrink-0 sm:pt-0.5">
            <span class="text-xs font-mono text-muted-foreground whitespace-nowrap">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
            <span class="text-xs text-muted-foreground/60">{post.data.readingTime}</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
