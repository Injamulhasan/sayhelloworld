---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Badge } from '@/components/ui/badge';
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from '@/components/ui/card';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<Layout title="Home — Injamul Hasan" description="Progressive Software Engineer & Frontend Developer Portfolio">
  <!-- Hero Section (Full Width with Bottom Border & Gradient) -->
  <section class="w-full bg-gradient-to-br from-muted/30 via-background to-muted/20 border-b border-border py-16 px-6">
    <div class="max-w-[1100px] mx-auto flex flex-col md:flex-row items-center md:items-start gap-12">
      <!-- Profile Image -->
      <div class="shrink-0">
        <img
          src="/injamul.jpg"
          alt="Injamul Hasan"
          class="w-40 h-40 rounded-full object-cover object-top border-4 border-primary shadow-[0_0_0_6px_rgba(59,130,246,0.15)] hover:scale-[1.02] transition-transform duration-300"
        />
      </div>

      <!-- Info -->
      <div class="flex-1 flex flex-col gap-4 text-center md:text-left items-center md:items-start">
        <div>
          <p class="text-xs font-bold uppercase tracking-wider text-primary mb-1.5 font-mono">
            Full Stack Developer · Lead Developer · Tech Writer
          </p>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-foreground">Injamul Hasan</h1>
        </div>
        
        <div class="text-center md:text-left text-sm text-muted-foreground leading-relaxed max-w-2xl space-y-3">
          <p>
            A Full Stack Web Application Developer who wires AI into web apps to kill the boring stuff, cut costs, and give businesses their time back.
          </p>
          <p>
            This is where I document what I learn about web and AI, minus the hype, plus a few tools when needed, and the architectural patterns behind them.
          </p>
        </div>

        <!-- Metadata items -->
        <div class="flex flex-wrap justify-center md:justify-start gap-x-6 gap-y-2 text-xs text-muted-foreground font-mono mt-1">
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Dhaka, Bangladesh
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            Lead Developer at Softvence Agency
          </span>
          <a href="mailto:injamulhasanakash@yahoo.com" class="flex items-center gap-1.5 hover:text-foreground transition-colors">
            <svg class="h-4 w-4 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v10a2 2 0 002 2z"></path>
            </svg>
            injamulhasanakash@yahoo.com
          </a>
        </div>

        <div class="flex flex-wrap justify-center md:justify-start gap-3 pt-2">
          <a
            href="mailto:injamulhasanakash@yahoo.com"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 transition-colors shadow-sm"
          >
            Get in touch
          </a>
          <a
            href="/projects"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border bg-background text-foreground text-sm font-medium hover:bg-muted transition-colors"
          >
            View Work
          </a>
          <a
            href="mailto:injamulhasanakash@yahoo.com?subject=Resume%20Request"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg border border-border bg-background text-foreground text-sm font-medium hover:bg-muted transition-colors"
          >
            Request Resume
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Rest of Content wrapped in 1100px container -->
  <div class="max-w-[1100px] mx-auto px-6 py-16 space-y-20">
    <!-- Bio / About -->
    <section class="space-y-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">About Me</h2>
      <div class="text-sm text-muted-foreground leading-relaxed max-w-4xl">
        <p>
          Results-driven Full Stack Developer with 1.3+ years of professional experience as Lead Developer at Softvence Agency. Proven expertise in multi-CMS team leadership (Webflow, Framer, Squarespace), full-stack web development, and delivering scalable client projects from concept to launch. Experienced in React, FastAPI, Django, and cloud technologies. Strong background in SEO best practices, performance optimization, and cross-functional collaboration with UI/UX teams.
        </p>
      </div>
    </section>

    <!-- Roles & Focus Grid (6 Cards, 3-column) -->
    <section class="space-y-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Focus & Roles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        
        <!-- Card 1: Lead Developer -->
        <Card class="flex flex-col transition-all hover:shadow-md hover:-translate-y-0.5 border-border/50 bg-card/40">
          <CardHeader class="pb-3">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <CardTitle class="text-base font-bold">Lead Developer @ Softvence</CardTitle>
          </CardHeader>
          <CardContent class="text-xs text-muted-foreground leading-relaxed flex-1">
            Results-driven Full Stack Developer with 1.3+ years of professional experience as Lead Developer. Proven expertise in multi-CMS team leadership, full-stack web development, and delivering scalable client projects from concept to launch.
          </CardContent>
        </Card>

        <!-- Card 2: Technical Arsenal -->
        <Card class="flex flex-col transition-all hover:shadow-md hover:-translate-y-0.5 border-border/50 bg-card/40">
          <CardHeader class="pb-3">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
              </svg>
            </div>
            <CardTitle class="text-base font-bold">Technical Arsenal</CardTitle>
          </CardHeader>
          <CardContent class="text-xs text-muted-foreground leading-relaxed flex-1">
            Proficient in React, FastAPI, Django, JavaScript/TypeScript, PHP, MySQL, Tailwind CSS, and GCP. CMS expert in Webflow, Squarespace, Wix, Framer, and WordPress. Focuses on clean architectures and SEO.
          </CardContent>
        </Card>

        <!-- Card 3: Explored Domains -->
        <Card class="flex flex-col transition-all hover:shadow-md hover:-translate-y-0.5 border-border/50 bg-card/40">
          <CardHeader class="pb-3">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
              </svg>
            </div>
            <CardTitle class="text-base font-bold">Explored Domains</CardTitle>
          </CardHeader>
          <CardContent class="text-xs text-muted-foreground leading-relaxed flex-1">
            Solid foundations in System Design, Data Structures & Algorithms, OS Concepts, Network Architecture, and Cloud Infrastructure. Bridging academic theories with production deployments.
          </CardContent>
        </Card>

        <!-- Card 4: My Power House -->
        <Card class="flex flex-col transition-all hover:shadow-md hover:-translate-y-0.5 border-border/50 bg-card/40">
          <CardHeader class="pb-3">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <CardTitle class="text-base font-bold">My Power House</CardTitle>
          </CardHeader>
          <CardContent class="text-xs text-muted-foreground leading-relaxed flex-1">
            Running Agile SDLC sprints, coding beautiful Figma designs, conducting code reviews, establishing design systems, maintaining DRY/SOLID codebases, and writing stakeholders' technical documentation.
          </CardContent>
        </Card>

        <!-- Card 5: Education -->
        <Card class="flex flex-col transition-all hover:shadow-md hover:-translate-y-0.5 border-border/50 bg-card/40">
          <CardHeader class="pb-3">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path>
              </svg>
            </div>
            <CardTitle class="text-base font-bold">Education</CardTitle>
          </CardHeader>
          <CardContent class="text-xs text-muted-foreground leading-relaxed flex-1">
            BSc in Computer Science, BRAC University (2018–2024). Active member of the Robotics Club (ROBU), building embedded control applications and automated hardware integrations.
          </CardContent>
        </Card>

        <!-- Card 6: CMS & Web App Projects -->
        <Card class="flex flex-col transition-all hover:shadow-md hover:-translate-y-0.5 border-border/50 bg-card/40">
          <CardHeader class="pb-3">
            <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-primary mb-3">
              <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </div>
            <CardTitle class="text-base font-bold">CMS & Web Apps</CardTitle>
          </CardHeader>
          <CardContent class="text-xs text-muted-foreground leading-relaxed flex-1">
            Developed custom applications across e-commerce, consulting, food, booking, and portfolio sectors. Prioritizing pixel-perfect layouts, responsive design, accessibility, and high performance.
          </CardContent>
        </Card>
      </div>
    </section>

    <!-- Work Experience Timeline -->
    <section class="space-y-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Detailed Work History</h2>
      <div class="space-y-8 relative before:absolute before:inset-y-1 before:left-3.5 before:w-0.5 before:bg-border/60">
        
        <!-- Role 1 -->
        <div class="relative pl-10 group">
          <div class="absolute left-1.5 top-1.5 w-4.5 h-4.5 rounded-full border-4 border-background bg-primary group-hover:scale-110 transition-transform duration-300"></div>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-2">
            <div>
              <h3 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors">Frontend Developer (Team Lead)</h3>
              <p class="text-sm text-muted-foreground">Softvence Agency · Full-time (On-site)</p>
            </div>
            <div class="sm:text-right">
              <span class="text-xs font-mono text-muted-foreground bg-muted px-2.5 py-1 rounded-md border border-border inline-block">Jul 2025 - May 2026 · 11 mos</span>
              <p class="text-[11px] text-muted-foreground/60 mt-1">Bangladesh</p>
            </div>
          </div>
          <p class="text-xs text-muted-foreground leading-relaxed mb-3">
            I’ve had the privilege of working on projects where I’ve not only optimized the design but also improved performance, increased client satisfaction, and contributed to significant growth in web traffic and sales. I’m always looking for new challenges and opportunities to create meaningful, high-quality web solutions.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {['JavaScript', 'JavaScript Libraries', 'Tailwind CSS', 'Webflow', 'Squarespace'].map(skill => (
              <Badge variant="secondary" class="text-[10px] font-mono">{skill}</Badge>
            ))}
          </div>
        </div>

        <!-- Role 2 -->
        <div class="relative pl-10 group">
          <div class="absolute left-1.5 top-1.5 w-4.5 h-4.5 rounded-full border-4 border-background bg-primary/70 group-hover:scale-110 transition-transform duration-300"></div>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-2">
            <div>
              <h3 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors">Frontend Developer (CMS)</h3>
              <p class="text-sm text-muted-foreground">Softvence Agency · Full-time (On-site)</p>
            </div>
            <div class="sm:text-right">
              <span class="text-xs font-mono text-muted-foreground bg-muted px-2.5 py-1 rounded-md border border-border inline-block">Apr 2025 - Jul 2025 · 4 mos</span>
              <p class="text-[11px] text-muted-foreground/60 mt-1">Dhaka, Bangladesh</p>
            </div>
          </div>
          <p class="text-xs text-muted-foreground leading-relaxed mb-3">
            Focused on developing robust and customizable content management workflows and layout elements with Webflow, WordPress, and Wix.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {['Webflow', 'WordPress', 'Wix', 'JavaScript', 'Tailwind CSS'].map(skill => (
              <Badge variant="secondary" class="text-[10px] font-mono">{skill}</Badge>
            ))}
          </div>
        </div>

        <!-- Role 3 -->
        <div class="relative pl-10 group">
          <div class="absolute left-1.5 top-1.5 w-4.5 h-4.5 rounded-full border-4 border-background bg-primary/40 group-hover:scale-110 transition-transform duration-300"></div>
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1 mb-2">
            <div>
              <h3 class="text-base font-semibold text-foreground group-hover:text-primary transition-colors">Trainee Web Developer</h3>
              <p class="text-sm text-muted-foreground">Softvence Agency · Full-time (On-site)</p>
            </div>
            <div class="sm:text-right">
              <span class="text-xs font-mono text-muted-foreground bg-muted px-2.5 py-1 rounded-md border border-border inline-block">Jan 2025 - Mar 2025 · 3 mos</span>
              <p class="text-[11px] text-muted-foreground/60 mt-1">Dhaka, Bangladesh</p>
            </div>
          </div>
          <p class="text-xs text-muted-foreground leading-relaxed mb-3">
            Hands-on learning of professional development workflows, building responsive layouts, and integrating backend scripts.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {['Webflow', 'JavaScript', 'PHP', 'MySQL', 'Bootstrap', 'Responsive layout'].map(skill => (
              <Badge variant="secondary" class="text-[10px] font-mono">{skill}</Badge>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- Education Details -->
    <section class="space-y-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Education</h2>
      <Card class="border-border/50 bg-card/50 transition-all duration-300 hover:border-primary/20">
        <CardHeader class="pb-3 flex flex-row items-start justify-between gap-4">
          <div>
            <CardTitle class="text-base font-bold text-foreground">BRAC University</CardTitle>
            <CardDescription class="text-sm text-muted-foreground mt-0.5">Bachelor of Science in Computer Science (BS CS)</CardDescription>
          </div>
          <span class="text-xs font-mono text-muted-foreground bg-muted px-2.5 py-1 rounded-md border border-border shrink-0">2018 – 2024</span>
        </CardHeader>
        <CardContent>
          <div class="text-xs text-muted-foreground space-y-1">
            <p class="font-medium text-foreground">Activities and Societies:</p>
            <p class="leading-relaxed">Robotics club of BRAC University - ROBU (engaged in building embedded control applications and hardware layouts).</p>
          </div>
        </CardContent>
      </Card>
    </section>

    <!-- Technical Arsenal Details -->
    <section class="space-y-6">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Technical Arsenal Breakdown</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        
        <!-- Frontend & Core -->
        <div class="space-y-2 p-4 rounded-xl border border-border/50 bg-card/30">
          <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-muted-foreground">Frontend & Core</h3>
          <div class="flex flex-wrap gap-1.5 pt-1">
            {['JavaScript', 'TypeScript', 'Tailwind CSS', 'Bootstrap (Framework)', 'jQuery', 'Responsive layout', 'PHP', 'Operating Systems'].map(skill => (
              <Badge variant="outline" class="text-xs font-mono">{skill}</Badge>
            ))}
          </div>
        </div>

        <!-- CMS & No-Code -->
        <div class="space-y-2 p-4 rounded-xl border border-border/50 bg-card/30">
          <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-muted-foreground">CMS & No-Code</h3>
          <div class="flex flex-wrap gap-1.5 pt-1">
            {['Webflow', 'Squarespace', 'Wix', 'WordPress'].map(skill => (
              <Badge variant="outline" class="text-xs font-mono">{skill}</Badge>
            ))}
          </div>
        </div>

        <!-- Cloud & Databases -->
        <div class="space-y-2 p-4 rounded-xl border border-border/50 bg-card/30">
          <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-muted-foreground">Cloud & Databases</h3>
          <div class="flex flex-wrap gap-1.5 pt-1">
            {['MySQL', 'Google Cloud Platform (GCP)'].map(skill => (
              <Badge variant="outline" class="text-xs font-mono">{skill}</Badge>
            ))}
          </div>
        </div>

        <!-- Interpersonal & Processes -->
        <div class="space-y-2 p-4 rounded-xl border border-border/50 bg-card/30">
          <h3 class="text-xs font-mono font-bold uppercase tracking-wider text-muted-foreground">Interpersonal & Processes</h3>
          <div class="flex flex-wrap gap-1.5 pt-1">
            {['Software Development Life Cycle (SDLC)', 'Business Analysis', 'Analytical Skills', 'Data Analysis', 'Technical Support'].map(skill => (
              <Badge variant="outline" class="text-xs font-mono">{skill}</Badge>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- Recent Blog Posts -->
    {recentPosts.length > 0 && (
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Recent Writing</h2>
          <a href="/blog" class="text-xs text-primary hover:underline">All posts</a>
        </div>
        <div class="space-y-px border border-border rounded-xl overflow-hidden">
          {recentPosts.map((post, i) => (
            <a
              href={`/blog/${post.slug}`}
              class={`flex flex-col sm:flex-row sm:items-center justify-between gap-2 px-5 py-4 bg-card hover:bg-muted/50 transition-colors group ${i > 0 ? 'border-t border-border' : ''}`}
            >
              <div class="flex flex-col gap-0.5">
                <span class="text-sm font-medium text-foreground group-hover:text-primary transition-colors">{post.data.title}</span>
                <span class="text-xs text-muted-foreground">{post.data.description}</span>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                {post.data.tags.slice(0, 1).map(tag => (
                  <Badge variant="outline" class="text-xs">{tag}</Badge>
                ))}
                <span class="text-xs text-muted-foreground font-mono">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
