---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import { ThemeProvider } from '@/components/ui/theme-toggle';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Portfolio',
  description = 'Personal portfolio and technical documentation',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ThemeProvider />
  </head>
  <body class="min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <footer class="border-t border-border py-8 mt-16">
      <div class="max-w-4xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted-foreground">
        <span>&copy; {new Date().getFullYear()} Your Name. All rights reserved.</span>
        <div class="flex gap-6">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">GitHub</a>
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">LinkedIn</a>
          <a href="https://scholar.google.com" target="_blank" rel="noopener noreferrer" class="hover:text-foreground transition-colors">Scholar</a>
        </div>
      </div>
    </footer>
  </body>
</html>
